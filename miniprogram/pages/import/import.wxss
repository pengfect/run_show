/**pages/import/import.wxss**/

page {
  background-color: #f5f5f5;
}

.form-group {
  margin-bottom: 20rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 10rpx;
  font-weight: 500;
}

.form-input {
  width: 100%;
  padding: 12rpx 16rpx;
  border: 1rpx solid #ddd;
  border-radius: 8rpx;
  font-size: 28rpx;
  background-color: #f9f9f9;
}

.form-input:disabled {
  background-color: #f0f0f0;
  color: #ccc;
}

.warning {
  background-color: #fffbf0;
  border-left: 4rpx solid #ff6b6b;
}

.result {
  border: 1rpx solid #ddd;
  border-radius: 8rpx;
}

.btn-primary {
  background-color: #ff6b6b;
  color: white;
  padding: 14rpx 28rpx;
  border-radius: 8rpx;
  font-size: 32rpx;
  border: none;
  width: 100%;
}

.btn-primary:active {
  background-color: #ff5252;
}

.btn-text {
  background-color: transparent;
  color: #ff6b6b;
  border: 1rpx solid #ff6b6b;
  padding: 10rpx 20rpx;
  border-radius: 6rpx;
  font-size: 26rpx;
  display: inline-block;
}

.btn-text:active {
  background-color: #fff5f5;
}
